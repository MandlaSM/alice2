@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero card compact">
    <div class="row wrap">
        <div>
            <span class="pill">Learner dashboard</span>
            <h1>Hello, @Model.UserFullName</h1>
            <p class="lead">Pick up where you left off and continue your enrolled courses.</p>
        </div>
        <div class="stats-row">
            <div class="stat card mini">
                <strong>@Model.EnrolledCourseCount</strong>
                <span>Courses</span>
            </div>
            <div class="stat card mini">
                <strong>@Model.CompletedLessonCount</strong>
                <span>Lessons completed</span>
            </div>
        </div>
    </div>
</section>

<section class="top-gap">
    <div class="row section-head wrap">
        <h2>My courses</h2>
        <a asp-controller="Courses" asp-action="Index" class="btn ghost small">View all courses</a>
    </div>

    <div class="grid">
        @foreach (var course in Model.Courses)
        {
            <article class="card course-card">
                <span class="pill">@course.HeroText</span>
                <h3>@course.Title</h3>
                <p>@course.Summary</p>
                <p class="muted">@course.CompletedLessons of @course.LessonCount lessons complete</p>
                <div class="progress"><span style="width:@course.ProgressPercent%"></span></div>
                <div class="row top-gap-sm">
                    <span class="muted">@course.ProgressPercent% complete</span>
                    <a asp-controller="Courses" asp-action="Details" asp-route-id="@course.Id" class="btn small">Open course</a>
                </div>
            </article>
        }
    </div>
</section>
